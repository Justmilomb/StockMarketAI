# Desktop app .env — only the keys baked into the build.
#
# Everything else lives elsewhere:
#   * Claude          — packaged engine, no separate key
#   * Trading 212     — entered by the user during onboarding
#   * Resend / Stripe — Render server env vars
#   * Twilio          — Render server env vars
#   * DATABASE_URL    — set automatically by Render

# market data (FMP Enterprise)
FMP_KEY=

# ML models — HuggingFace has two scopes:
#   HF_TOKEN_READ  — downloads (Kronos, FinBERT, Chronos, TimesFM).
#                    This is what the app uses on every model load.
#   HF_TOKEN_WRITE — uploads / push_to_hub. Only needed if we ever
#                    publish fine-tuned weights from this build.
HF_TOKEN_READ=
HF_TOKEN_WRITE=
