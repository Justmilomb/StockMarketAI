{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#ff3b3b;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;margin:0 0 14px;">licence expiring</div>
<h1 style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;font-size:26px;font-weight:300;letter-spacing:-0.01em;color:#ffffff;margin:0 0 16px;line-height:1.3;">your licence expires soon, {{ name|e }}.</h1>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:15px;line-height:1.65;margin:0 0 16px;">
your blank licence expires on <span style="color:#ff3b3b;font-family:'JetBrains Mono','Consolas','Courier New',monospace;">{{ expires_at|e }}</span>. after that the desktop app stops placing trades until you renew.
</p>
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:rgba(255,255,255,0.32);font-size:10px;letter-spacing:0.28em;text-transform:uppercase;margin:24px 0 8px;">licence key</div>
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#ffffff;font-size:14px;background:#000000;border:1px solid rgba(255,255,255,0.08);padding:12px 16px;word-break:break-all;letter-spacing:0.04em;">{{ license_key|e }}</div>
<p style="margin:24px 0 0;">
<a href="{{ renew_url|e }}" style="display:inline-block;background:#00ff87;color:#000000;text-decoration:none;font-family:'JetBrains Mono','Consolas','Courier New',monospace;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;padding:14px 28px;border:1px solid #00ff87;font-weight:500;">renew now</a>
</p>
{% endblock %}
