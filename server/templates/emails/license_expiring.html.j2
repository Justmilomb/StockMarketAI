{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono',monospace;color:#ffb020;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:8px;">licence expiring</div>
<h1 style="font-size:26px;font-weight:200;margin:0 0 16px;">your licence expires soon, {{ name|e }}.</h1>
<p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.6;margin:0 0 12px;">
Your blank licence expires on <span style="color:#ffb020;font-family:'JetBrains Mono',monospace;">{{ expires_at|e }}</span>. After that the desktop app stops placing trades until you renew.
</p>
<div style="font-family:'JetBrains Mono',monospace;color:rgba(255,255,255,0.4);font-size:11px;margin:20px 0 6px;letter-spacing:0.2em;text-transform:uppercase;">licence key</div>
<div style="font-family:'JetBrains Mono',monospace;color:#ffffff;font-size:14px;background:#0a0a0a;border:1px solid rgba(255,255,255,0.12);padding:12px 16px;word-break:break-all;">{{ license_key|e }}</div>
<p style="margin:24px 0;">
<a href="{{ renew_url|e }}" style="display:inline-block;background:#00ff87;color:#000000;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.06em;text-transform:uppercase;padding:14px 28px;border:1px solid #00ff87;">Renew now</a>
</p>
{% endblock %}
