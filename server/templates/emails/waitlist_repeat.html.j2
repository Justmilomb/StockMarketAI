{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono',monospace;color:#00ff87;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:8px;">we see you</div>
<h1 style="font-size:28px;font-weight:300;margin:0 0 16px;">you signed up again. we love the energy.</h1>
<p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.6;margin:0 0 20px;">
rest assured — you're locked in. your email has been on our list since the start, and it's not going anywhere.
</p>
<p style="color:rgba(255,255,255,0.55);font-size:14px;line-height:1.7;margin:0 0 16px;">
when blank launches on <span style="color:#00ff87;font-family:'JetBrains Mono',monospace;">{{ launch_date|e }}</span>, you'll be one of the first to know. we'll email you before we go anywhere near social media.
</p>
<p style="color:rgba(255,255,255,0.4);font-size:13px;line-height:1.6;margin:0;">
if you have questions, just reply to this email. we read everything.
</p>
{% endblock %}
