{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#00ff87;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;margin:0 0 14px;">licence renewed</div>
<h1 style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;font-size:26px;font-weight:300;letter-spacing:-0.01em;color:#ffffff;margin:0 0 16px;line-height:1.3;">you're good to go, {{ name|e }}.</h1>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:15px;line-height:1.65;margin:0 0 16px;">
your blank licence is renewed. nothing to do &mdash; the desktop app will pick it up next time it checks in.
</p>
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:rgba(255,255,255,0.32);font-size:10px;letter-spacing:0.28em;text-transform:uppercase;margin:24px 0 8px;">licence key</div>
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#ffffff;font-size:14px;background:#000000;border:1px solid rgba(255,255,255,0.08);padding:12px 16px;word-break:break-all;letter-spacing:0.04em;">{{ license_key|e }}</div>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:13px;line-height:1.65;margin:20px 0 0;">
next renewal: <span style="color:#00ff87;font-family:'JetBrains Mono','Consolas','Courier New',monospace;">{{ next_renewal|e }}</span>.
</p>
{% endblock %}
