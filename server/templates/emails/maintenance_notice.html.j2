{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#ff3b3b;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;margin:0 0 14px;">scheduled maintenance</div>
<h1 style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;font-size:28px;font-weight:300;letter-spacing:-0.01em;color:#ffffff;margin:0 0 16px;line-height:1.25;">brief downtime ahead.</h1>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:15px;line-height:1.65;margin:0 0 16px;">
the blank licence server will be unavailable from
<span style="color:#ffffff;font-family:'JetBrains Mono','Consolas','Courier New',monospace;">{{ start_time|e }}</span> to
<span style="color:#ffffff;font-family:'JetBrains Mono','Consolas','Courier New',monospace;">{{ end_time|e }}</span>.
</p>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:14px;line-height:1.65;margin:0 0 16px;">
the desktop app keeps running during this window &mdash; trades still happen. only licence checks and updates pause. no action needed.
</p>
{% if reason %}
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.32);font-size:13px;line-height:1.65;margin:0;">reason: {{ reason|e }}.</p>
{% endif %}
{% endblock %}
