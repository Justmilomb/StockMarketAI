{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono',monospace;color:#ffb020;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:8px;">scheduled maintenance</div>
<h1 style="font-size:28px;font-weight:200;margin:0 0 16px;">Brief downtime ahead.</h1>
<p style="color:rgba(255,255,255,0.7);font-size:15px;line-height:1.6;margin:0 0 16px;">
The blank licence server will be unavailable from
<strong style="color:#ffffff;">{{ start_time|e }}</strong> to
<strong style="color:#ffffff;">{{ end_time|e }}</strong>.
</p>
<p style="color:rgba(255,255,255,0.7);font-size:14px;line-height:1.6;margin:0 0 16px;">
The desktop app keeps running during this window — trades still happen. Only licence checks and updates pause. No action needed.
</p>
{% if reason %}
<p style="color:rgba(255,255,255,0.5);font-size:13px;line-height:1.6;">Reason: {{ reason|e }}.</p>
{% endif %}
{% endblock %}
