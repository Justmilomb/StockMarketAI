{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono',monospace;color:#ffb020;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:8px;">action required</div>
<h1 style="font-size:26px;font-weight:200;margin:0 0 16px;">{{ headline|e }}</h1>
<p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.7;margin:0 0 20px;">
Hi {{ name|e }} &mdash; {{ body|e }}
</p>
<p style="margin:0 0 24px;">
<a href="{{ cta_url|e }}" style="display:inline-block;background:#ffb020;color:#000000;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.06em;text-transform:uppercase;padding:14px 28px;border:1px solid #ffb020;">{{ cta_label|e }}</a>
</p>
<p style="color:rgba(255,255,255,0.5);font-size:13px;line-height:1.6;">
Questions? Just reply to this email.
</p>
{% endblock %}
