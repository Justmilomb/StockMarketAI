{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#00ff87;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:8px;">two weeks in</div>
<h1 style="font-size:26px;font-weight:200;margin:0 0 16px;">how's blank treating you, {{ name|e }}?</h1>
<p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.6;margin:0 0 20px;">
You've been running blank for a couple of weeks. What's working, what isn't? Five minutes of your time would genuinely shape where this goes next.
</p>
<p style="margin:0 0 24px;">
<a href="{{ form_url|e }}" style="display:inline-block;background:#00ff87;color:#000000;text-decoration:none;font-family:'JetBrains Mono','Consolas','Courier New',monospace;font-size:13px;letter-spacing:0.06em;text-transform:uppercase;padding:14px 28px;border:1px solid #00ff87;">Leave feedback</a>
</p>
<p style="color:rgba(255,255,255,0.5);font-size:13px;line-height:1.6;">
Or just hit reply. Brutal honesty welcome.
</p>
{% endblock %}
