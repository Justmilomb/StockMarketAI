{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#ff3b3b;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;margin:0 0 14px;">incident</div>
<h1 style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;font-size:26px;font-weight:300;letter-spacing:-0.01em;color:#ffffff;margin:0 0 16px;line-height:1.3;">something's not right.</h1>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:15px;line-height:1.65;margin:0 0 24px;">
{{ summary|e }}
</p>
<p style="margin:0 0 24px;">
<a href="{{ status_url|e }}" style="display:inline-block;background:transparent;color:#00ff87;text-decoration:none;font-family:'JetBrains Mono','Consolas','Courier New',monospace;font-size:12px;letter-spacing:0.15em;text-transform:uppercase;padding:14px 28px;border:1px solid #00ff87;font-weight:500;">view status page</a>
</p>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.32);font-size:13px;line-height:1.65;margin:0;">
the desktop app keeps running. only licence checks pause while we sort it.
</p>
{% endblock %}
