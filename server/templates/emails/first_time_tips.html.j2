{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#00ff87;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:8px;">day one</div>
<h1 style="font-size:26px;font-weight:200;margin:0 0 16px;">getting the most out of blank, {{ name|e }}.</h1>
<p style="color:rgba(255,255,255,0.75);font-size:15px;line-height:1.6;margin:0 0 20px;">
You've had blank running for about a day. Here are a few things worth knowing now that the novelty has worn off.
</p>
<ol style="color:rgba(255,255,255,0.7);font-size:14px;line-height:1.8;padding-left:20px;margin:0;">
{% for tip in tips %}
  <li style="margin-bottom:10px;">{{ tip|e }}</li>
{% endfor %}
</ol>
<p style="color:rgba(255,255,255,0.5);font-size:13px;line-height:1.6;margin:24px 0 0;">
Stuck on anything? Just reply to this email.
</p>
{% endblock %}
