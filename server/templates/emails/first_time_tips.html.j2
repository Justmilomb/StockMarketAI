{% extends "_layout.html.j2" %}
{% block content %}
<div style="font-family:'JetBrains Mono','Consolas','Courier New',monospace;color:#00ff87;font-size:11px;letter-spacing:0.28em;text-transform:uppercase;margin:0 0 14px;">day one</div>
<h1 style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;font-size:26px;font-weight:300;letter-spacing:-0.01em;color:#ffffff;margin:0 0 16px;line-height:1.3;">getting the most out of blank, {{ name|e }}.</h1>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:15px;line-height:1.65;margin:0 0 20px;">
you've had blank running for about a day. here are a few things worth knowing now that the novelty has worn off.
</p>
<ol style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.6);font-size:14px;line-height:1.8;padding-left:20px;margin:0;">
{% for tip in tips %}
  <li style="margin-bottom:10px;">{{ tip|e }}</li>
{% endfor %}
</ol>
<p style="font-family:'Outfit','Helvetica Neue',Arial,sans-serif;color:rgba(255,255,255,0.32);font-size:13px;line-height:1.65;margin:24px 0 0;">
stuck on anything? just reply to this email.
</p>
{% endblock %}
